[
  {
    "label": "nixos-rebuild switch",
    "command": "sudo nixos-rebuild",
    "args": ["switch", "--flake", "${ZED_WORKTREE_ROOT}#${HOSTNAME}"],
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "reveal_target": "dock",
    "hide": "never",
    "shell": "system",
    "show_summary": true,
    "show_command": true,
  },
]
